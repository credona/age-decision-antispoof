{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://credona.dev/schemas/antispoof-benchmark-report.schema.json",
  "title": "Age Decision AntiSpoof Benchmark Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "benchmark_id",
    "benchmark_version",
    "generated_at",
    "service",
    "service_version",
    "contract_version",
    "benchmark_target",
    "dataset",
    "machine",
    "runtime",
    "metrics",
    "privacy"
  ],
  "properties": {
    "benchmark_id": {
      "type": "string",
      "minLength": 1
    },
    "benchmark_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "service": {
      "type": "string",
      "enum": [
        "antispoof"
      ]
    },
    "service_version": {
      "type": "string",
      "minLength": 1
    },
    "contract_version": {
      "type": "string",
      "minLength": 1
    },
    "benchmark_target": {
      "type": "string",
      "enum": [
        "model",
        "service"
      ]
    },
    "dataset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "split",
        "sample_count",
        "license",
        "source_reference"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "split": {
          "type": "string",
          "enum": [
            "calibration",
            "test",
            "validation"
          ]
        },
        "sample_count": {
          "type": "integer",
          "minimum": 0
        },
        "license": {
          "type": "string",
          "minLength": 1
        },
        "source_reference": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "machine": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cpu",
        "ram_gb",
        "gpu",
        "hosting_provider",
        "os",
        "docker_version"
      ],
      "properties": {
        "cpu": {
          "type": "string",
          "minLength": 1
        },
        "ram_gb": {
          "type": "number",
          "minimum": 0
        },
        "gpu": {
          "type": "string"
        },
        "hosting_provider": {
          "type": "string",
          "minLength": 1
        },
        "os": {
          "type": "string",
          "minLength": 1
        },
        "docker_version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "docker_image",
        "docker_image_digest",
        "seed",
        "command"
      ],
      "properties": {
        "docker_image": {
          "type": "string",
          "minLength": 1
        },
        "docker_image_digest": {
          "type": "string"
        },
        "seed": {
          "type": "integer"
        },
        "command": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "latency_ms_avg",
        "latency_ms_p95",
        "throughput_rps",
        "label_distribution",
        "error_rates"
      ],
      "properties": {
        "latency_ms_avg": {
          "type": "number",
          "minimum": 0
        },
        "latency_ms_p95": {
          "type": "number",
          "minimum": 0
        },
        "throughput_rps": {
          "type": "number",
          "minimum": 0
        },
        "label_distribution": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "real",
            "spoof"
          ],
          "properties": {
            "real": {
              "type": "integer",
              "minimum": 0
            },
            "spoof": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "error_rates": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "apcer",
            "bpcer",
            "acer",
            "attack_count",
            "bona_fide_count"
          ],
          "properties": {
            "apcer": {
              "type": "number",
              "minimum": 0
            },
            "bpcer": {
              "type": "number",
              "minimum": 0
            },
            "acer": {
              "type": "number",
              "minimum": 0
            },
            "attack_count": {
              "type": "integer",
              "minimum": 0
            },
            "bona_fide_count": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contains_sensitive_data",
        "contains_raw_inputs",
        "contains_internal_scores",
        "contains_internal_thresholds"
      ],
      "properties": {
        "contains_sensitive_data": {
          "type": "boolean",
          "const": false
        },
        "contains_raw_inputs": {
          "type": "boolean",
          "const": false
        },
        "contains_internal_scores": {
          "type": "boolean",
          "const": false
        },
        "contains_internal_thresholds": {
          "type": "boolean",
          "const": false
        }
      }
    }
  }
}
